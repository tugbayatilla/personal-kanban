{
  "name": "personal-kanban",
  "displayName": "Personal Kanban",
  "description": "File-based personal kanban board for VSCode",
  "version": "0.0.10",
  "publisher": "tugbay",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "personal-kanban.initBoard",
        "title": "Personal Kanban: Init Board"
      },
      {
        "command": "personal-kanban.openBoard",
        "title": "Personal Kanban: Open Board"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
